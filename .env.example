# Copy to `.env` and fill in. `.env` is gitignored.

# --- API keys ---
# Step 03 (concept generation) needs an OpenAI key.
OPENAI_API_KEY=
# Step 01 (ImageNet / Places365 download from HuggingFace) needs an HF token.
HF_TOKEN=

# --- paths (all optional; sensible repo-root defaults live in paths.py) ---
# Point these at a large scratch disk if you don't want data/ inside the repo.
LAD_ROOT=
LAD_DATA_ROOT=
LAD_IMAGENET_ROOT=
LAD_FILTERED_ROOT=
LAD_NPZ_ROOT=
LAD_CONCEPTS_DIR=
LAD_OUTPUT_ROOT=
LAD_MODELS_DIR=

# --- retinal (ODIR-5K) clinical track ---
LAD_RETINAL_ROOT=
LAD_RETINAL_CONCEPTS_DIR=

# --- framework caches (optional) ---
TORCH_HOME=
HF_HOME=
